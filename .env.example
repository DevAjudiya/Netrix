# ─────────────────────────────────────────
# Netrix — .env.example (root)
# Purpose: Root-level environment variable template
# Author: Netrix Development Team
# ─────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# This file is used by docker-compose.yml
# ─────────────────────────────────────────

# ========================
# Application Settings
# ========================
APP_NAME=Netrix
APP_VERSION=1.0.0
DEBUG=False

# ========================
# Security & Authentication
# ========================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================
# MySQL Database
# ========================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=netrix_user
MYSQL_PASSWORD=netrix_secure_password_123
MYSQL_DATABASE=netrix_db
MYSQL_ROOT_PASSWORD=netrix_root_secret

# ========================
# Redis Cache
# ========================
REDIS_URL=redis://redis:6379

# ========================
# Scanner Configuration
# ========================
NMAP_PATH=/usr/bin/nmap
MAX_SCAN_THREADS=10
MAX_SCANS_PER_USER_PER_HOUR=5

# ========================
# CVE / Vulnerability Data
# ========================
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=
OFFLINE_CVE_DB_PATH=./data/cve_offline.json

# ========================
# Reports
# ========================
REPORTS_DIR=./reports

# ========================
# Network & CORS
# ========================
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000
