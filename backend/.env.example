# ─────────────────────────────────────────
# Netrix — .env.example
# Purpose: Environment variable template for the Netrix backend
# Author: Netrix Development Team
# ─────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ─────────────────────────────────────────

# ========================
# Application Settings
# ========================
# Name of the application (displayed in UI and logs)
APP_NAME=Netrix
# Application version string
APP_VERSION=1.0.0
# Enable debug mode (set to False in production)
DEBUG=False

# ========================
# Security & Authentication
# ========================
# Secret key for signing JWT tokens (generate a strong random string)
# Example: openssl rand -hex 64
SECRET_KEY=your-super-secret-key-change-this-in-production
# JWT signing algorithm
ALGORITHM=HS256
# Access token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================
# MySQL Database
# ========================
# MySQL server hostname (use 'mysql' when running inside Docker)
MYSQL_HOST=localhost
# MySQL server port
MYSQL_PORT=3306
# MySQL database user
MYSQL_USER=netrix_user
# MySQL database password
MYSQL_PASSWORD=netrix_secure_password_123
# MySQL database name
MYSQL_DATABASE=netrix_db
# MySQL root password (used by Docker to initialize the database)
MYSQL_ROOT_PASSWORD=netrix_root_secret

# ========================
# Redis Cache
# ========================
# Redis connection URL (use 'redis://redis:6379' when running inside Docker)
REDIS_URL=redis://localhost:6379

# ========================
# Scanner Configuration
# ========================
# Full path to the nmap binary on the host system
NMAP_PATH=/usr/bin/nmap
# Maximum number of concurrent scan threads
MAX_SCAN_THREADS=10
# Maximum scans allowed per user per hour (rate limiting)
MAX_SCANS_PER_USER_PER_HOUR=5

# ========================
# CVE / Vulnerability Data
# ========================
# NVD (National Vulnerability Database) REST API URL
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
# NVD API key for higher rate limits (optional, get one at https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=
# Path to the offline CVE database JSON file (fallback when NVD is unavailable)
OFFLINE_CVE_DB_PATH=./data/cve_offline.json

# ========================
# Reports
# ========================
# Directory where generated reports are saved
REPORTS_DIR=./reports

# ========================
# Network & CORS
# ========================
# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1
# Comma-separated list of allowed CORS origins (frontend URLs)
CORS_ORIGINS=http://localhost:3000
