# Netrix — .env (root)
# Used by docker-compose

# ========================
# Application Settings
# ========================
APP_NAME=Netrix
APP_VERSION=1.0.0
DEBUG=False

# ========================
# Security & Authentication
# ========================
JWT_SECRET_KEY=1d404a890f8a0899021725bd2ce2050d94e5606a38b351a1f13daa4e94e01129
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================
# Initial Admin Account
# ========================
ADMIN_USERNAME=admin
ADMIN_EMAIL=devajudiya01@outlook.com
ADMIN_PASSWORD=Admin@Netrix2026!

# ========================
# MySQL Database
# (MYSQL_HOST and REDIS_URL are overridden to Docker service names in docker-compose.yml)
# ========================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=netrix_user
MYSQL_PASSWORD=NetrixDB@2026!
MYSQL_DATABASE=netrix_db
MYSQL_ROOT_PASSWORD=NetrixRoot@2026!

# ========================
# Redis Cache
# ========================
REDIS_URL=redis://redis:6379

# ========================
# Scanner Configuration
# ========================
NMAP_PATH=/usr/bin/nmap
MAX_SCAN_THREADS=10
MAX_SCANS_PER_USER_PER_HOUR=5

# ========================
# CVE / Vulnerability Data
# ========================
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=004bdea6-be04-4252-b987-22275e447b84
OFFLINE_CVE_DB_PATH=./data/cve_offline.json

# ========================
# Reports
# ========================
REPORTS_DIR=./reports

# ========================
# Network & CORS
# ========================
ALLOWED_HOSTS=["localhost","127.0.0.1"]
CORS_ORIGINS=["http://localhost:3000"]
